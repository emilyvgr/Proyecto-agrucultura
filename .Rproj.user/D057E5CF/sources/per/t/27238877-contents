  # Función para identificar atípicos

  resumen_atipicos_tabla <- function(df) {
    # 1. Calculamos las métricas por columna
    resumen <- lapply(names(Data_Agricultura), function(col_name) {
      col_data <- Data_Agricultura[[col_name]]
      total_n <- length(col_data)
      
      if (is.numeric(col_data)) {
        q1 <- quantile(col_data, 0.25, na.rm = TRUE)
        q3 <- quantile(col_data, 0.75, na.rm = TRUE)
        iqr <- q3 - q1
        n_out <- sum(col_data < (q1 - 1.5 * iqr) | col_data > (q3 + 1.5 * iqr), na.rm = TRUE)
        tipo <- "Numérica"
      } else {
        counts <- table(col_data)
        prop <- prop.table(counts)
        n_out <- sum(counts[prop < 0.01]) # Categorías con menos del 1%
        tipo <- "Categórica"
      }
      
      # Creamos una fila por variable
      data.frame(
        Variable = col_name,
        Tipo = tipo,
        Cant_Atipicos = n_out,
        Porcentaje = round((n_out / total_n) * 100, 2)
      )
    })
    
    # 2. Unimos todo en un solo dataframe
    bind_rows(resumen)
  }
  


